PORT=3000
# Optional in GitHub Actions because github.token is injected automatically.
# Still useful for local simulation.
GITHUB_TOKEN=ghp_your_token_here
GH_APP_ID=
GH_APP_PRIVATE_KEY=
GH_APP_INSTALLATION_ID=
CODEX_API_KEY=sk-...
CODEX_BASE_URL=https://api.openai.com/v1
CODEX_MODEL=gpt-5.4
CODEX_REASONING_EFFORT=high

# Optional controls
BOT_NAME=github-actions[bot]
AUTO_MERGE=false
MERGE_METHOD=squash
REQUIRE_CHECKS=true
MAX_PATCH_CHARS=120000
LOG_LEVEL=info
