    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^4.77.0",
    "pino": "^9.5.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@vercel/node": "^5.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
