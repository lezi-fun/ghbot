{
  "name": "ghbot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <26"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:vercel": "vercel dev",
