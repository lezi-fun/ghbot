{
  "version": 2,
  "builds": [
    {
      "src": "api/github/webhooks.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60
      }
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/api/github/webhooks.ts"
    },
    {
      "src": "^/api/github/webhooks$",
      "dest": "/api/github/webhooks.ts"
    },
    {
      "src": "^/webhooks/github$",
      "dest": "/api/github/webhooks.ts"
    },
    {
      "src": "^/(.*)$",
      "status": 404
    }
  ]
}
